{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "EksClusterPolicy",
            "Effect": "Allow",
            "Action": "eks:DescribeCluster",
            "Resource": "arn:aws:eks:eu-west-1:085430451857:cluster/EKS-staging"
        },
        {
            "Sid": "EksVpcClusterPolicy",
            "Effect": "Allow",
            "Action": [
                "ec2:DescribeDhcpOptions",
                "ec2:DescribeNetworkInterfaces",
                "ec2:DescribeRouteTables",
                "ec2:DescribeSubnets",
                "ec2:DescribeSecurityGroups",
                "ec2:DescribeVpcs"
            ],
            "Resource": ["*"]
        },
        {
            "Sid": "CreateNetworkInterfacePolicy",
            "Effect": "Allow",
            "Action": "ec2:CreateNetworkInterface",
            "Resource": [
                "arn:aws:ec2:eu-west-1:085430451857:subnet/subnet-0b50db4a12b149977",
                "arn:aws:ec2:eu-west-1:085430451857:subnet/subnet-01dea153893c89bbb",
                "arn:aws:ec2:eu-west-1:085430451857:subnet/subnet-0619eee9fabd1a2e7"
            ]
        },
        {
            "Sid": "CreateNetworkInterfacePermissionPolicy",
            "Effect": "Allow",
            "Action": "ec2:CreateNetworkInterfacePermission",
            "Resource": "arn:aws:ec2:eu-west-1:085430451857:network-interface/eni-*",
            "Condition": {
                "ArnEquals": {
                    "ec2:Subnet": [
                        "arn:aws:ec2:eu-west-1:085430451857:subnet/subnet-0b50db4a12b149977",
                        "arn:aws:ec2:eu-west-1:085430451857:subnet/subnet-01dea153893c89bbb",
                        "arn:aws:ec2:eu-west-1:085430451857:subnet/subnet-0619eee9fabd1a2e7"
                    ]
                }
            }
        },
        {
            "Sid": "DeleteNetworkInterfacePolicy",
            "Effect": "Allow",
            "Action": "ec2:DeleteNetworkInterface",
            "Resource": "arn:aws:ec2:eu-west-1:085430451857:network-interface/eni-*",
            "Condition": {
                "ArnEquals": {
                    "ec2:Subnet": [
                        "arn:aws:ec2:eu-west-1:085430451857:subnet/subnet-0b50db4a12b149977",
                        "arn:aws:ec2:eu-west-1:085430451857:subnet/subnet-01dea153893c89bbb",
                        "arn:aws:ec2:eu-west-1:085430451857:subnet/subnet-0619eee9fabd1a2e7"
                    ]
                }
            }
        },
        {
            "Sid": "NetworkInterfacePermissionCheckPolicy",
            "Effect": "Allow",
            "Action": [
                "ec2:CreateNetworkInterface",
                "ec2:DeleteNetworkInterface"
            ],
            "Resource": "*",
            "Condition": {
                "StringNotLike": {
                    "ec2:SubnetId": "subnet-*",
                    "ec2:NetworkInterfaceId": "eni-*"
                }
            }
        }
    ]
}
